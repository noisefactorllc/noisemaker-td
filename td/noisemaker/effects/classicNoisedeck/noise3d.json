{
  "name": "Noise3d",
  "namespace": "classicNoisedeck",
  "func": "noise3d",
  "starter": true,
  "tags": [
    "3d",
    "noise"
  ],
  "description": "3D noise volumes",
  "paramAliases": {
    "noiseScale": "scale",
    "noiseType": "type"
  },
  "globals": {
    "type": {
      "type": "int",
      "default": 12,
      "define": "NOISE_TYPE",
      "choices": {
        "cubes": 50,
        "simplex": 12,
        "sine": 30,
        "spheres": 40,
        "wavyPlanes": 60,
        "wavyPlaneLower": 61,
        "wavyPlaneUpper": 62
      }
    },
    "ridges": {
      "type": "boolean",
      "default": false,
      "uniform": "ridges"
    },
    "seed": {
      "type": "int",
      "default": 1,
      "uniform": "seed",
      "min": 1,
      "max": 100
    },
    "speed": {
      "type": "int",
      "default": 1,
      "uniform": "speed",
      "min": -10,
      "max": 10,
      "zero": 0
    },
    "scale": {
      "type": "float",
      "default": 25,
      "uniform": "scale",
      "min": 1,
      "max": 100
    },
    "offsetX": {
      "type": "float",
      "default": 0,
      "uniform": "offsetX",
      "min": -100,
      "max": 100
    },
    "offsetY": {
      "type": "float",
      "default": 0,
      "uniform": "offsetY",
      "min": -100,
      "max": 100
    },
    "colorMode": {
      "type": "int",
      "default": 6,
      "uniform": "colorMode",
      "choices": {
        "depthMap": 8,
        "hsv": 6,
        "mono": 0,
        "surfaceNormal": 7
      }
    },
    "hueRotation": {
      "type": "float",
      "default": 0,
      "uniform": "hueRotation",
      "min": 0,
      "max": 360
    },
    "hueRange": {
      "type": "float",
      "default": 10,
      "uniform": "hueRange",
      "min": 0,
      "max": 100
    }
  },
  "passes": [
    {
      "name": "render",
      "program": "noise3d",
      "inputs": {},
      "outputs": {
        "fragColor": "outputTex"
      }
    }
  ],
  "textures": {}
}
