{
  "name": "Composite",
  "namespace": "classicNoisedeck",
  "func": "composite",
  "starter": false,
  "tags": [
    "color"
  ],
  "description": "Multi-layer compositing",
  "paramAliases": {
    "mixAmt": "mix"
  },
  "globals": {
    "tex": {
      "type": "surface",
      "default": "none",
      "uniform": "tex"
    },
    "blendMode": {
      "type": "int",
      "default": 1,
      "uniform": "blendMode",
      "choices": {
        "colorSplash": 0,
        "greenscreenAB": 1,
        "greenscreenBA": 2,
        "aBBlack": 3,
        "aBColorBlack": 4,
        "aBHue": 5,
        "aBSaturation": 6,
        "aBValue": 7,
        "bABlack": 8,
        "bAColorBlack": 9,
        "bAHue": 10,
        "bASaturation": 11,
        "bAValue": 12,
        "mix": 13,
        "psychedelic": 14,
        "psychedelic2": 15
      }
    },
    "inputColor": {
      "type": "color",
      "default": [
        0,
        0,
        0
      ],
      "uniform": "inputColor"
    },
    "range": {
      "type": "float",
      "default": 20,
      "uniform": "range",
      "min": 0,
      "max": 100
    },
    "mix": {
      "type": "float",
      "default": 50,
      "uniform": "mixAmt",
      "min": 0,
      "max": 100
    }
  },
  "passes": [
    {
      "name": "render",
      "program": "composite",
      "inputs": {
        "inputTex": "inputTex",
        "tex": "tex"
      },
      "uniforms": {
        "mixAmt": "mix"
      },
      "outputs": {
        "fragColor": "outputTex"
      }
    }
  ],
  "textures": {}
}
