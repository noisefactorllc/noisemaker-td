{
  "name": "Moodscape",
  "namespace": "classicNoisedeck",
  "func": "moodscape",
  "starter": true,
  "tags": [
    "noise"
  ],
  "description": "Refracted value noise with multiple color modes",
  "paramAliases": {
    "loopAmp": "speed"
  },
  "globals": {
    "interp": {
      "type": "int",
      "default": 10,
      "define": "NOISE_TYPE",
      "choices": {
        "constant": 0,
        "linear": 1,
        "hermite": 2,
        "catmullRom3x3": 3,
        "catmullRom4x4": 4,
        "bSpline3x3": 5,
        "bSpline4x4": 6,
        "simplex": 10,
        "sine": 11
      }
    },
    "noiseScale": {
      "type": "float",
      "default": 85,
      "uniform": "noiseScale",
      "min": 1,
      "max": 200
    },
    "speed": {
      "type": "float",
      "default": 25,
      "uniform": "speed",
      "min": 0,
      "max": 100,
      "zero": 0
    },
    "refractAmt": {
      "type": "float",
      "default": 5,
      "uniform": "refractAmt",
      "min": 0,
      "max": 100
    },
    "ridges": {
      "type": "boolean",
      "default": true,
      "uniform": "ridges"
    },
    "wrap": {
      "type": "boolean",
      "default": true,
      "uniform": "wrap"
    },
    "seed": {
      "type": "int",
      "default": 44,
      "uniform": "seed",
      "min": 0,
      "max": 100
    },
    "colorMode": {
      "type": "int",
      "default": 2,
      "define": "COLOR_MODE",
      "choices": {
        "mono": 0,
        "rgb": 1,
        "hsv": 2,
        "oklab": 3
      }
    },
    "hueRotation": {
      "type": "float",
      "default": 180,
      "uniform": "hueRotation",
      "min": 0,
      "max": 360
    },
    "hueRange": {
      "type": "float",
      "default": 25,
      "uniform": "hueRange",
      "min": 0,
      "max": 100
    },
    "intensity": {
      "type": "float",
      "default": 0,
      "uniform": "intensity",
      "min": -100,
      "max": 100
    }
  },
  "passes": [
    {
      "name": "render",
      "program": "moodscape",
      "inputs": {},
      "outputs": {
        "fragColor": "outputTex"
      }
    }
  ],
  "textures": {}
}
