{
  "name": "Texture",
  "namespace": "filter",
  "func": "texture",
  "starter": false,
  "tags": [
    "noise"
  ],
  "description": "Texture overlay blend",
  "paramAliases": {},
  "globals": {
    "mode": {
      "type": "int",
      "default": 3,
      "define": "MODE",
      "choices": {
        "canvas": 0,
        "crosshatch": 1,
        "halftone": 2,
        "paper": 3,
        "stucco": 4
      }
    },
    "alpha": {
      "type": "float",
      "default": 0.5,
      "uniform": "alpha",
      "min": 0,
      "max": 1
    },
    "scale": {
      "type": "float",
      "default": 1,
      "uniform": "scale",
      "min": 0.1,
      "max": 10
    }
  },
  "passes": [
    {
      "name": "main",
      "program": "texture",
      "inputs": {
        "inputTex": "inputTex"
      },
      "uniforms": {
        "alpha": "alpha",
        "scale": "scale"
      },
      "outputs": {
        "fragColor": "outputTex"
      }
    }
  ],
  "textures": {},
  "defaultProgram": "search filter, synth\n\nsolid(color: #d1d1d1)\n  .texture(alpha: 0.75)\n  .write(o0)"
}
