{
  "name": "Motion Blur",
  "namespace": "filter",
  "func": "motionBlur",
  "starter": false,
  "tags": [
    "lens",
    "blur"
  ],
  "description": "Simple motion blur via frame blending",
  "paramAliases": {},
  "globals": {
    "amount": {
      "type": "float",
      "default": 50,
