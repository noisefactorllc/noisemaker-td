{
  "name": "Lighting",
  "namespace": "filter",
  "func": "lighting",
  "starter": false,
  "tags": [
    "color"
  ],
  "description": "Applies 3D lighting effects",
  "paramAliases": {},
  "globals": {
    "normalStrength": {
      "type": "float",
      "default": 1.5,
      "uniform": "normalStrength",
      "min": 0,
      "max": 5
    },
    "smoothing": {
      "type": "float",
      "default": 1,
      "uniform": "smoothing",
      "min": 1,
      "max": 10
    },
    "diffuseColor": {
      "type": "color",
      "default": [
        1,
        1,
        1
      ],
      "uniform": "diffuseColor"
    },
    "specularColor": {
      "type": "color",
      "default": [
        1,
        1,
        1
      ],
      "uniform": "specularColor"
    },
    "specularIntensity": {
      "type": "float",
      "default": 0.5,
      "uniform": "specularIntensity",
      "min": 0,
      "max": 2
    },
    "shininess": {
      "type": "float",
      "default": 64,
      "uniform": "shininess",
      "min": 8,
      "max": 256
    },
    "ambientColor": {
      "type": "color",
      "default": [
        0.2,
        0.2,
        0.2
      ],
      "uniform": "ambientColor"
    },
    "lightDirection": {
      "type": "vec3",
      "default": [
        0.5,
        0.5,
        1
      ],
      "uniform": "lightDirection"
    },
    "reflection": {
      "type": "float",
      "default": 0,
      "uniform": "reflection",
      "min": 0,
      "max": 100
    },
    "refraction": {
      "type": "float",
      "default": 0,
      "uniform": "refraction",
      "min": 0,
      "max": 100
    },
    "aberration": {
      "type": "float",
      "default": 0,
      "uniform": "aberration",
      "min": 0,
      "max": 100
    }
  },
  "passes": [
    {
      "name": "render",
      "program": "lighting",
      "inputs": {
        "inputTex": "inputTex"
      },
      "outputs": {
        "fragColor": "outputTex"
      }
    }
  ],
  "textures": {},
  "defaultProgram": "search filter, synth\n\nnoise(ridges: true)\n.lighting(normalStrength: 2)\n.write(o0)"
}
