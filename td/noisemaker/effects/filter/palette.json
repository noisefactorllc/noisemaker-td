{
  "name": "Palette",
  "namespace": "filter",
  "func": "palette",
  "starter": false,
  "tags": [
    "color",
    "palette"
  ],
  "description": "Apply cosine color palettes based on luminance",
  "paramAliases": {
    "paletteIndex": "index",
    "paletteOffset": "offset",
    "paletteRepeat": "repeat",
    "paletteRotation": "rotation"
  },
  "globals": {
    "index": {
      "type": "member",
      "default": "palette.brushedMetal",
      "uniform": "paletteIndex",
      "enum": "palette"
    },
    "rotation": {
      "type": "float",
      "default": 0,
      "uniform": "rotation",
      "choices": {
        "none": 0,
        "fwd": 1,
        "back": -1
      }
    },
    "offset": {
      "type": "float",
      "default": 0,
      "uniform": "offset",
      "min": 0,
      "max": 100
    },
    "repeat": {
      "type": "int",
      "default": 1,
      "uniform": "repeat",
      "min": 1,
      "max": 10
    },
    "alpha": {
      "type": "float",
      "default": 1,
      "uniform": "alpha",
      "min": 0,
      "max": 1
    }
  },
  "passes": [
    {
      "name": "render",
      "program": "palette",
      "inputs": {
        "inputTex": "inputTex"
      },
      "outputs": {
        "fragColor": "outputTex"
      }
    }
  ],
  "textures": {}
}
