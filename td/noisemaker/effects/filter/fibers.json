{
  "name": "Fibers",
  "namespace": "filter",
  "func": "fibers",
  "starter": false,
  "tags": [
    "noise"
  ],
  "description": "Chaotic fiber texture overlay",
  "paramAliases": {},
  "globals": {
    "density": {
      "type": "float",
      "default": 0.5,
      "uniform": "density",
      "min": 0,
      "max": 1
    },
    "seed": {
      "type": "int",
      "default": 1,
      "uniform": "seed",
      "min": 1,
      "max": 100
    },
    "alpha": {
      "type": "float",
      "default": 0.5,
      "uniform": "alpha",
      "min": 0,
      "max": 1
    }
  },
  "passes": [
    {
      "name": "blend",
      "program": "fibersBlend",
      "inputs": {
        "inputTex": "inputTex",
        "overlayTex": "overlayTex"
      },
      "uniforms": {
        "alpha": "alpha"
      },
      "outputs": {
        "fragColor": "outputTex"
      }
    }
  ],
  "textures": {
    "overlayTex": {
      "width": "screen",
      "height": "screen",
      "format": "rgba8"
    }
  },
  "defaultProgram": "search filter, synth\n\nsolid(color: #000000)\n.fibers(density: 1)\n.write(o0)"
}
