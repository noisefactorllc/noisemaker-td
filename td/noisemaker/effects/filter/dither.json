{
  "name": "Dither",
  "namespace": "filter",
  "func": "dither",
  "starter": false,
  "tags": [
    "color",
    "pixel"
  ],
  "description": "Ordered dithering with classic patterns and palettes",
  "paramAliases": {
    "ditherType": "type",
    "mixAmount": "mix"
  },
  "globals": {
    "type": {
      "type": "int",
      "default": 1,
      "uniform": "ditherType",
      "choices": {
        "bayer2x2": 0,
        "bayer4x4": 1,
        "bayer8x8": 2,
        "dot": 3,
        "line": 4,
        "crosshatch": 5,
        "noise": 6
      }
    },
    "matrixScale": {
      "type": "int",
      "default": 2,
      "uniform": "matrixScale",
      "min": 1,
      "max": 8
    },
    "threshold": {
      "type": "float",
      "default": 0,
      "uniform": "threshold",
      "min": -0.5,
      "max": 0.5
    },
    "palette": {
      "type": "int",
      "default": 0,
      "uniform": "palette",
      "choices": {
        "input": 0,
        "monochrome": 1,
        "dotMatrixGreen": 2,
        "amberMonitor": 3,
        "pico8": 4,
        "commodore64": 5,
        "cgaPalette1": 6,
        "zxSpectrum": 7,
        "appleII": 8,
        "ega": 9
      }
    },
    "levels": {
      "type": "int",
      "default": 4,
      "uniform": "levels",
      "min": 2,
      "max": 16
    },
    "mix": {
      "type": "float",
      "default": 1,
      "uniform": "mixAmount",
      "min": 0,
      "max": 1
    }
  },
  "passes": [
    {
      "name": "render",
      "program": "dither",
      "inputs": {
        "inputTex": "inputTex"
      },
      "outputs": {
        "fragColor": "outputTex"
      }
    }
  ],
  "textures": {}
}
