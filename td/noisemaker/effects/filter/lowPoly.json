{
  "name": "Low Poly",
  "namespace": "filter",
  "func": "lowPoly",
  "starter": false,
  "tags": [
    "geometric",
    "noise"
  ],
  "description": "Low-polygon style render using Voronoi cells",
  "paramAliases": {
    "freq": "scale",
    "nth": "mode"
  },
  "globals": {
    "scale": {
      "type": "int",
      "default": 50,
      "uniform": "scale",
      "min": 2,
      "max": 100
    },
    "seed": {
      "type": "int",
      "default": 1,
      "uniform": "seed",
      "min": 1,
      "max": 100
    },
    "mode": {
      "type": "int",
      "default": 1,
      "uniform": "mode",
      "choices": {
        "flat": 0,
        "edges": 1,
        "distance2": 2,
        "distance3": 3
      }
    },
    "edgeStrength": {
      "type": "float",
      "default": 0.15,
      "uniform": "edgeStrength",
      "min": 0,
      "max": 1
    },
    "edgeColor": {
      "type": "color",
      "default": [
        0,
        0,
        0
      ],
      "uniform": "edgeColor"
    },
    "alpha": {
      "type": "float",
      "default": 1,
      "uniform": "alpha",
      "min": 0,
      "max": 1
    },
    "speed": {
      "type": "int",
      "default": 0,
      "uniform": "speed",
      "min": 0,
      "max": 5,
      "zero": 0
    }
  },
  "passes": [
    {
      "name": "render",
      "program": "lowPoly",
      "inputs": {
        "inputTex": "inputTex"
      },
      "outputs": {
        "fragColor": "outputTex"
      }
    }
  ],
  "textures": {}
}
