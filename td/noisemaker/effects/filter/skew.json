{
  "name": "Skew",
  "namespace": "filter",
  "func": "skew",
  "starter": false,
  "tags": [
    "transform"
  ],
  "description": "Skew and rotate transform",
  "paramAliases": {},
  "globals": {
    "skew": {
      "type": "float",
      "default": 0.25,
      "uniform": "skewAmt",
      "min": -1,
      "max": 1,
      "zero": 0
    },
    "rotate": {
      "type": "float",
      "default": 0,
      "uniform": "rotation",
      "min": -180,
      "max": 180
    },
    "wrap": {
      "type": "int",
      "default": 1,
      "uniform": "wrap",
      "choices": {
        "clamp": 0,
        "mirror": 1,
        "repeat": 2
      }
    }
  },
  "passes": [
    {
      "name": "render",
      "program": "skew",
      "inputs": {
        "inputTex": "inputTex"
      },
      "outputs": {
        "fragColor": "outputTex"
      }
    }
  ],
  "textures": {},
  "defaultProgram": "search filter, synth\n\ntestPattern()\n.skew(wrap: repeat)\n.write(o0)"
}
