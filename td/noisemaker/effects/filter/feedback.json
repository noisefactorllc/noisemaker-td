{
  "name": "Feedback",
  "namespace": "filter",
  "func": "feedback",
  "starter": false,
  "tags": [
    "sim"
  ],
  "description": "Feedback loop with blend modes and transforms",
  "paramAliases": {
    "mixAmt": "mix",
    "aberrationAmt": "aberration"
  },
  "globals": {
    "blendMode": {
      "type": "int",
      "default": 10,
      "uniform": "blendMode",
      "choices": {
        "add": 0,
        "cloak": 100,
        "colorBurn": 2,
        "colorDodge": 3,
        "darken": 4,
        "difference": 5,
        "exclusion": 6,
        "glow": 7,
        "hardLight": 8,
        "lighten": 9,
        "mix": 10,
        "multiply": 11,
        "negation": 12,
        "overlay": 13,
        "phoenix": 14,
        "reflect": 15,
        "screen": 16,
        "softLight": 17,
        "subtract": 18
      }
    },
    "mix": {
      "type": "float",
      "default": 0,
      "uniform": "mixAmt",
      "min": 0,
      "max": 100
    },
    "scaleAmt": {
      "type": "float",
      "default": 100,
      "uniform": "scaleAmt",
      "min": 75,
      "max": 200
    },
    "rotation": {
      "type": "float",
      "default": 0,
      "uniform": "rotation",
      "min": -180,
      "max": 180
    },
    "refractAAmt": {
      "type": "float",
      "default": 0,
      "uniform": "refractAAmt",
      "min": 0,
      "max": 100
    },
    "refractBAmt": {
      "type": "float",
      "default": 0,
      "uniform": "refractBAmt",
      "min": 0,
      "max": 100
    },
    "refractADir": {
      "type": "float",
      "default": 0,
      "uniform": "refractADir",
      "min": 0,
      "max": 360
    },
    "refractBDir": {
      "type": "float",
      "default": 0,
      "uniform": "refractBDir",
      "min": 0,
      "max": 360
    },
    "hueRotation": {
      "type": "float",
      "default": 0,
      "uniform": "hueRotation",
      "min": -180,
      "max": 180
    },
    "intensity": {
      "type": "float",
      "default": 0,
      "uniform": "intensity",
      "min": -100,
      "max": 100
    },
    "aberration": {
      "type": "float",
      "default": 0,
      "uniform": "aberration",
      "min": 0,
      "max": 100
    },
    "distortion": {
      "type": "float",
      "default": 0,
      "uniform": "distortion",
      "min": -100,
      "max": 100
    },
    "resetState": {
      "type": "boolean",
      "default": false,
      "uniform": "resetState"
    }
  },
  "passes": [
    {
      "name": "main",
      "program": "feedback",
      "inputs": {
        "inputTex": "inputTex",
        "selfTex": "_selfTex"
      },
      "outputs": {
        "fragColor": "outputTex"
      }
    },
    {
      "name": "feedback",
      "program": "copy",
      "inputs": {
        "inputTex": "outputTex"
      },
      "outputs": {
        "fragColor": "_selfTex"
      }
    }
  ],
  "textures": {
    "_selfTex": {
      "width": "input",
      "height": "input",
      "format": "rgba8unorm"
    }
  }
}
