{
  "name": "RenderCubemapSurface",
  "namespace": "render",
  "func": "renderCubemapSurface",
  "starter": false,
  "tags": [
    "3d"
  ],
  "description": "Sample a 3D volume into cubemap faces (raw true color, no lighting)",
  "paramAliases": {},
  "globals": {
    "volumeSize": {
      "type": "int",
      "default": 64,
      "uniform": "volumeSize",
      "choices": {
        "v16": 16,
        "v32": 32,
        "v64": 64,
        "v128": 128
      }
    },
    "density": {
      "type": "float",
      "default": 4,
      "uniform": "density",
      "min": 0,
      "max": 20
    },
    "absorption": {
      "type": "float",
      "default": 1,
      "uniform": "absorption",
      "min": 0,
      "max": 4
    },
    "emission": {
      "type": "float",
      "default": 1,
      "uniform": "emission",
      "min": 0,
      "max": 4
    },
    "cubeBasis": {
      "type": "mat3",
      "default": [
        1,
        0,
        0,
        0,
        1,
        0,
        0,
        0,
        1
      ],
      "uniform": "cubeBasis"
    },
    "bgColor": {
      "type": "color",
      "default": [
        0.02,
        0.02,
        0.02
      ],
      "uniform": "bgColor"
    },
    "bgAlpha": {
      "type": "float",
      "default": 1,
      "uniform": "bgAlpha",
      "min": 0,
      "max": 1
    }
  },
  "passes": [
    {
      "name": "render",
      "program": "renderCubemapSurface",
      "inputs": {
        "volumeCache": "inputTex3d",
        "analyticalGeo": "inputGeo"
      },
      "outputs": {
        "color": "outputTex",
        "geoOut": "screenGeoBuffer"
      },
      "drawBuffers": 2
    }
  ],
  "textures": {
    "screenGeoBuffer": {
      "width": "resolution",
      "height": "resolution",
      "format": "rgba16f"
    }
  },
  "outputTex3d": "inputTex3d",
  "outputGeo": "screenGeoBuffer"
}
