{
  "name": "RenderCubemap3D",
  "namespace": "render",
  "func": "renderCubemap3D",
  "starter": false,
  "tags": [
    "3d"
  ],
  "description": "Render a 3D volume into cubemap faces (lit isosurface/voxel)",
  "paramAliases": {},
  "globals": {
    "volumeSize": {
      "type": "int",
      "default": 64,
      "uniform": "volumeSize",
      "choices": {
        "v16": 16,
        "v32": 32,
        "v64": 64,
        "v128": 128
      }
    },
    "filtering": {
      "type": "int",
      "default": 0,
      "define": "FILTERING",
      "choices": {
        "isosurface": 0,
        "voxel": 1
      }
    },
    "threshold": {
      "type": "float",
      "default": 0.5,
      "uniform": "threshold",
      "min": 0,
      "max": 1
    },
    "invert": {
      "type": "boolean",
      "default": false,
      "define": "INVERT"
    },
    "cubeBasis": {
      "type": "mat3",
      "default": [
        1,
        0,
        0,
        0,
        1,
        0,
        0,
        0,
        1
      ],
      "uniform": "cubeBasis"
    },
    "bgColor": {
      "type": "color",
      "default": [
        0.02,
        0.02,
        0.02
      ],
      "uniform": "bgColor"
    },
    "bgAlpha": {
      "type": "float",
      "default": 1,
      "uniform": "bgAlpha",
      "min": 0,
      "max": 1
    }
  },
  "passes": [
    {
      "name": "render",
      "program": "renderCubemap3D",
      "inputs": {
        "volumeCache": "inputTex3d",
        "analyticalGeo": "inputGeo"
      },
      "outputs": {
        "color": "outputTex",
        "geoOut": "screenGeoBuffer"
      },
      "drawBuffers": 2
    }
  ],
  "textures": {
    "screenGeoBuffer": {
      "width": "resolution",
      "height": "resolution",
      "format": "rgba16f"
    }
  },
  "outputTex3d": "inputTex3d",
  "outputGeo": "screenGeoBuffer"
}
