{
  "name": "Cell3D",
  "namespace": "synth3d",
  "func": "cell3d",
  "starter": true,
  "tags": [
    "3d",
    "noise"
  ],
  "description": "3D cellular/Voronoi noise volume",
  "paramAliases": {
    "cellVariation": "variation"
  },
  "globals": {
    "volumeSize": {
      "type": "int",
      "default": 64,
      "uniform": "volumeSize",
      "choices": {
        "x16": 16,
        "x32": 32,
        "x64": 64,
        "x128": 128
      }
    },
    "metric": {
      "type": "int",
      "default": 0,
      "uniform": "metric",
      "choices": {
        "sphere": 0,
        "octahedron": 1,
        "cube": 2
      }
    },
    "scale": {
      "type": "float",
      "default": 10,
      "uniform": "scale",
      "min": 1,
      "max": 15
    },
    "variation": {
      "type": "float",
      "default": 100,
      "uniform": "cellVariation",
      "min": 0,
      "max": 100
    },
    "seed": {
      "type": "int",
      "default": 1,
      "uniform": "seed",
      "min": 0,
      "max": 100
    },
    "colorMode": {
      "type": "int",
      "default": 1,
      "uniform": "colorMode",
      "choices": {
        "mono": 0,
        "rgb": 1
      }
    }
  },
  "passes": [
    {
      "name": "precompute",
      "program": "precompute",
      "inputs": {},
      "outputs": {
        "color": "volumeCache",
        "geoOut": "geoBuffer"
      },
      "drawBuffers": 2
    }
  ],
  "textures": {
    "volumeCache": {
      "width": {
        "param": "volumeSize",
        "default": 64
      },
      "height": {
        "param": "volumeSize",
        "power": 2,
        "default": 4096
      },
      "format": "rgba16f"
    },
    "geoBuffer": {
      "width": {
        "param": "volumeSize",
        "default": 64
      },
      "height": {
        "param": "volumeSize",
        "power": 2,
        "default": 4096
      },
      "format": "rgba16f"
    }
  },
  "outputTex3d": "volumeCache",
  "outputGeo": "geoBuffer"
}
