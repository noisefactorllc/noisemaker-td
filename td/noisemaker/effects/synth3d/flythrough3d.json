{
  "name": "Flythrough3D",
  "namespace": "synth3d",
  "func": "flythrough3d",
  "starter": true,
  "tags": [
    "3d",
    "fractal"
  ],
  "description": "3D fractal flythrough with camera-relative volume",
  "paramAliases": {
    "fractalType": "type"
  },
  "globals": {
    "volumeSize": {
      "type": "int",
      "default": 64,
      "uniform": "volumeSize",
      "choices": {
        "x16": 16,
        "x32": 32,
        "x64": 64,
        "x128": 128
      }
    },
    "type": {
      "type": "int",
      "default": 0,
      "uniform": "noiseType",
      "choices": {
        "mandelbulb": 0,
        "mandelbox": 1
      }
    },
    "power": {
      "type": "float",
      "default": 8,
      "uniform": "power",
      "min": -3,
      "max": 16
    },
    "iterations": {
      "type": "int",
      "default": 12,
      "uniform": "iterations",
      "min": 4,
      "max": 24
    },
    "bailout": {
      "type": "float",
      "default": 4,
      "uniform": "bailout",
      "min": 1,
      "max": 16
    },
    "speed": {
      "type": "float",
      "default": 0.2,
      "uniform": "speed",
      "min": 0,
      "max": 1,
      "zero": 0
    },
    "voiSize": {
      "type": "float",
      "default": 0.5,
      "uniform": "voiSize",
      "min": 0.1,
      "max": 2
    },
    "seed": {
      "type": "int",
      "default": 0,
      "uniform": "seed",
      "min": 0,
      "max": 100
    }
  },
  "passes": [
    {
      "name": "precompute",
      "program": "precompute",
      "inputs": {},
      "outputs": {
        "color": "volumeCache",
        "geoOut": "geoBuffer"
      },
      "drawBuffers": 2
    }
  ],
  "textures": {
    "volumeCache": {
      "width": {
        "param": "volumeSize",
        "default": 64
      },
      "height": {
        "param": "volumeSize",
        "power": 2,
        "default": 4096
      },
      "format": "rgba16f"
    },
    "geoBuffer": {
      "width": {
        "param": "volumeSize",
        "default": 64
      },
      "height": {
        "param": "volumeSize",
        "power": 2,
        "default": 4096
      },
      "format": "rgba16f"
    }
  },
  "outputTex3d": "volumeCache",
  "outputGeo": "geoBuffer"
}
