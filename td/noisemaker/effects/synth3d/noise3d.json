{
  "name": "Noise3D",
  "namespace": "synth3d",
  "func": "noise3d",
  "starter": true,
  "tags": [
    "3d",
    "noise"
  ],
  "description": "3D simplex noise volume",
  "paramAliases": {},
  "globals": {
    "volumeSize": {
      "type": "int",
      "default": 64,
      "uniform": "volumeSize",
      "choices": {
        "x16": 16,
        "x32": 32,
        "x64": 64,
        "x128": 128
      }
    },
    "scale": {
      "type": "float",
      "default": 3,
      "uniform": "scale",
      "min": 0,
      "max": 100
    },
    "octaves": {
      "type": "int",
      "default": 1,
      "define": "OCTAVES",
      "min": 1,
      "max": 6
    },
    "colorMode": {
      "type": "int",
      "default": 0,
      "define": "COLOR_MODE",
      "choices": {
        "mono": 0,
        "rgb": 1
      }
    },
    "ridges": {
      "type": "boolean",
      "default": false,
      "define": "RIDGES"
    },
    "seed": {
      "type": "int",
      "default": 0,
      "uniform": "seed",
      "min": 0,
      "max": 100
    },
    "speed": {
      "type": "int",
      "default": 1,
      "uniform": "speed",
      "min": 0,
      "max": 5,
      "zero": 0
    }
  },
  "passes": [
    {
      "name": "precompute",
      "program": "precompute",
      "inputs": {},
      "outputs": {
        "color": "volumeCache",
        "geoOut": "geoBuffer"
      },
      "drawBuffers": 2
    }
  ],
  "textures": {
    "volumeCache": {
      "width": {
        "param": "volumeSize",
        "default": 64
      },
      "height": {
        "param": "volumeSize",
        "power": 2,
        "default": 4096
      },
      "format": "rgba16f"
    },
    "geoBuffer": {
      "width": {
        "param": "volumeSize",
        "default": 64
      },
      "height": {
        "param": "volumeSize",
        "power": 2,
        "default": 4096
      },
      "format": "rgba16f"
    }
  },
  "outputTex3d": "volumeCache",
  "outputGeo": "geoBuffer"
}
