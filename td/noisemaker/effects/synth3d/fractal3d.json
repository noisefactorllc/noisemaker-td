{
  "name": "Fractal3D",
  "namespace": "synth3d",
  "func": "fractal3d",
  "starter": true,
  "tags": [
    "3d"
  ],
  "description": "3D Mandelbulb/Mandelcube fractals",
  "paramAliases": {
    "fractalType": "type"
  },
  "globals": {
    "volumeSize": {
      "type": "int",
      "default": 64,
      "uniform": "volumeSize",
      "choices": {
        "x16": 16,
        "x32": 32,
        "x64": 64,
        "x128": 128
      }
    },
    "type": {
      "type": "int",
      "default": 0,
      "uniform": "noiseType",
      "choices": {
        "mandelbulb": 0,
        "mandelcube": 1,
        "juliaBulb": 2,
        "juliaCube": 3
      }
    },
    "power": {
      "type": "float",
      "default": 8,
      "uniform": "power",
      "min": 2,
      "max": 16
    },
    "iterations": {
      "type": "int",
      "default": 10,
      "uniform": "iterations",
      "min": 1,
      "max": 20
    },
    "bailout": {
      "type": "float",
      "default": 2,
      "uniform": "bailout",
      "min": 1,
      "max": 8
    },
    "juliaX": {
      "type": "float",
      "default": 0,
      "uniform": "juliaX",
      "min": -100,
      "max": 100
    },
    "juliaY": {
      "type": "float",
      "default": 0,
      "uniform": "juliaY",
      "min": -100,
      "max": 100
    },
    "juliaZ": {
      "type": "float",
      "default": 0,
      "uniform": "juliaZ",
      "min": -100,
      "max": 100
    },
    "colorMode": {
      "type": "int",
      "default": 0,
      "uniform": "colorMode",
      "choices": {
        "mono": 0,
        "orbitTrap": 1,
        "iteration": 2
      }
    }
  },
  "passes": [
    {
      "name": "precompute",
      "program": "precompute",
      "inputs": {},
      "outputs": {
        "color": "volumeCache",
        "geoOut": "geoBuffer"
      },
      "drawBuffers": 2
    }
  ],
  "textures": {
    "volumeCache": {
      "width": {
        "param": "volumeSize",
        "default": 64
      },
      "height": {
        "param": "volumeSize",
        "power": 2,
        "default": 4096
      },
      "format": "rgba16f"
    },
    "geoBuffer": {
      "width": {
        "param": "volumeSize",
        "default": 64
      },
      "height": {
        "param": "volumeSize",
        "power": 2,
        "default": 4096
      },
      "format": "rgba16f"
    }
  },
  "outputTex3d": "volumeCache",
  "outputGeo": "geoBuffer"
}
