{
  "name": "Flock",
  "namespace": "points",
  "func": "flock",
  "starter": false,
  "tags": [
    "sim"
  ],
  "description": "2D \"Boids\" flocking agent simulation",
  "paramAliases": {},
  "globals": {
    "separation": {
      "type": "float",
      "default": 2,
      "uniform": "separation",
      "min": 0,
      "max": 5
    },
    "alignment": {
      "type": "float",
      "default": 1,
      "uniform": "alignment",
      "min": 0,
      "max": 5
    },
    "cohesion": {
      "type": "float",
      "default": 1,
      "uniform": "cohesion",
      "min": 0,
      "max": 5
    },
    "perceptionRadius": {
      "type": "float",
      "default": 50,
      "uniform": "perceptionRadius",
      "min": 10,
      "max": 200
    },
    "separationRadius": {
      "type": "float",
      "default": 25,
      "uniform": "separationRadius",
      "min": 5,
      "max": 100
    },
    "maxSpeed": {
      "type": "float",
      "default": 4,
      "uniform": "maxSpeed",
      "min": 0.5,
      "max": 10
    },
    "maxForce": {
      "type": "float",
      "default": 0.3,
      "uniform": "maxForce",
      "min": 0.01,
      "max": 1
    },
    "boundaryMode": {
      "type": "int",
      "default": 0,
      "uniform": "boundaryMode",
      "choices": {
        "wrap": 0,
        "softWall": 1
      }
    },
    "wallMargin": {
      "type": "float",
      "default": 50,
      "uniform": "wallMargin",
      "min": 10,
      "max": 200
    },
    "noiseWeight": {
      "type": "float",
      "default": 0.1,
      "uniform": "noiseWeight",
      "min": 0,
      "max": 1
    }
  },
  "passes": [
    {
      "name": "agent",
      "program": "agent",
      "inputs": {
        "xyzTex": "global_xyz",
        "velTex": "global_vel",
        "rgbaTex": "global_rgba"
      },
      "uniforms": {
        "separation": "separation",
        "alignment": "alignment",
        "cohesion": "cohesion",
        "perceptionRadius": "perceptionRadius",
        "separationRadius": "separationRadius",
        "maxSpeed": "maxSpeed",
        "maxForce": "maxForce",
        "boundaryMode": "boundaryMode",
        "wallMargin": "wallMargin",
        "noiseWeight": "noiseWeight"
      },
      "outputs": {
        "outXYZ": "global_xyz",
        "outVel": "global_vel",
        "outRGBA": "global_rgba"
      },
      "drawBuffers": 3
    },
    {
      "name": "passthrough",
      "program": "passthrough",
      "inputs": {
        "inputTex": "inputTex"
      },
      "outputs": {
        "fragColor": "outputTex"
      }
    }
  ],
  "textures": {}
}
