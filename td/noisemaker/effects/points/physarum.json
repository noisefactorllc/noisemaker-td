{
  "name": "Physarum",
  "namespace": "points",
  "func": "physarum",
  "starter": false,
  "tags": [
    "sim"
  ],
  "description": "Physarum slime mold simulation",
  "paramAliases": {},
  "globals": {
    "moveSpeed": {
      "type": "float",
      "default": 1.78,
      "uniform": "moveSpeed",
      "min": 0.05,
      "max": 3
    },
    "turnSpeed": {
      "type": "float",
      "default": 1,
      "uniform": "turnSpeed",
      "min": 0,
      "max": 3.14159
    },
    "sensorAngle": {
      "type": "float",
      "default": 1.26,
      "uniform": "sensorAngle",
      "min": 0.1,
      "max": 1.5
    },
    "sensorDistance": {
      "type": "float",
      "default": 0.03,
      "uniform": "sensorDistance",
      "min": 0.002,
      "max": 0.1
    },
    "inputWeight": {
      "type": "float",
      "default": 0,
      "uniform": "inputWeight",
      "min": 0,
      "max": 100
    },
    "deposit": {
      "type": "float",
      "default": 0.5,
      "uniform": "deposit",
      "min": 0,
      "max": 1
    },
    "decay": {
      "type": "float",
      "default": 0.1,
      "uniform": "decay",
      "min": 0,
      "max": 1
    },
    "resetState": {
      "type": "boolean",
      "default": false,
      "uniform": "resetState"
    }
  },
  "passes": [
    {
      "name": "decayTrail",
      "program": "diffuse",
      "inputs": {
        "trailTex": "global_physarum_pheromone"
      },
      "uniforms": {
        "decay": "decay",
        "resetState": "resetState"
      },
      "outputs": {
        "fragColor": "global_physarum_pheromone"
      }
    },
    {
      "name": "agent",
      "program": "agent",
      "inputs": {
        "xyzTex": "global_xyz",
        "velTex": "global_vel",
        "rgbaTex": "global_rgba",
        "trailTex": "global_physarum_pheromone",
        "inputTex": "inputTex"
      },
      "uniforms": {
        "moveSpeed": "moveSpeed",
        "turnSpeed": "turnSpeed",
        "sensorAngle": "sensorAngle",
        "sensorDistance": "sensorDistance",
        "inputWeight": "inputWeight"
      },
      "outputs": {
        "outXYZ": "global_xyz",
        "outVel": "global_vel",
        "outRGBA": "global_rgba"
      },
      "drawBuffers": 3
    },
    {
      "name": "copy",
      "program": "passthrough",
      "inputs": {
        "inputTex": "global_physarum_pheromone"
      },
      "outputs": {
        "fragColor": "global_physarum_pheromone"
      }
    },
    {
      "name": "deposit",
      "program": "deposit",
      "inputs": {
        "xyzTex": "global_xyz",
        "rgbaTex": "global_rgba"
      },
      "uniforms": {
        "deposit": "deposit"
      },
      "outputs": {
        "fragColor": "global_physarum_pheromone"
      },
      "drawMode": "points",
      "count": "input",
      "blend": true
    },
    {
      "name": "passthrough",
      "program": "passthrough",
      "inputs": {
        "inputTex": "inputTex"
      },
      "outputs": {
        "fragColor": "outputTex"
      }
    }
  ],
  "textures": {
    "global_physarum_pheromone": {
      "width": "100%",
      "height": "100%",
      "format": "rgba16f"
    }
  }
}
