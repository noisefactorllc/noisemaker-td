{
  "name": "Hydraulic",
  "namespace": "points",
  "func": "hydraulic",
  "starter": false,
  "tags": [
    "sim"
  ],
  "description": "Hydraulic erosion flow simulation (gradient descent)",
  "paramAliases": {},
