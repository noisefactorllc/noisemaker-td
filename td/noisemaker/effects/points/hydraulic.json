    "stride": {
      "type": "float",
      "default": 10,
      "uniform": "stride",
      "min": 1,
      "max": 1000
    },
    "quantize": {
      "type": "boolean",
      "default": false,
      "uniform": "quantize"
    },
    "inverse": {
      "type": "boolean",
      "default": false,
      "uniform": "inverse"
    },
    "inputWeight": {
      "type": "float",
      "default": 100,
      "uniform": "inputWeight",
      "min": 0,
      "max": 100
    }
  },
  "passes": [
