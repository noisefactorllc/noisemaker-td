{
  "name": "Cell",
  "namespace": "synth",
  "func": "cell",
  "starter": true,
  "tags": [
    "noise",
    "geometric"
  ],
  "description": "Cellular/Voronoi noise with distance metrics",
  "paramAliases": {
    "cellVariation": "variation",
    "loopAmp": "speed"
  },
  "globals": {
    "shape": {
      "type": "int",
      "default": 0,
      "uniform": "metric",
      "choices": {
        "circle": 0,
        "diamond": 1,
        "hexagon": 2,
        "octagon": 3,
        "square": 4,
        "triangle": 6
      }
    },
    "scale": {
      "type": "float",
      "default": 75,
      "uniform": "scale",
      "min": 1,
      "max": 100
    },
    "cellScale": {
      "type": "float",
      "default": 87,
      "uniform": "cellScale",
      "min": 1,
      "max": 100
    },
    "cellSmooth": {
      "type": "float",
      "default": 0,
      "uniform": "cellSmooth",
      "min": 0,
      "max": 100
