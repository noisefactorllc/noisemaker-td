{
  "name": "Mandala",
  "namespace": "synth",
  "func": "mandala",
  "starter": true,
  "tags": [
    "geometric",
    "pattern"
  ],
  "description": "N-fold symmetric mandala generator",
  "paramAliases": {},
  "globals": {
    "scale": {
      "type": "float",
      "default": 10,
      "uniform": "scale",
      "min": 1,
      "max": 20
