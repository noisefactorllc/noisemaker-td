{
  "name": "Perlin",
  "namespace": "synth",
  "func": "perlin",
  "starter": true,
  "tags": [
    "noise"
  ],
  "description": "Perlin-like noise with optional warping",
  "paramAliases": {},
  "globals": {
    "scale": {
      "type": "float",
      "default": 25,
      "uniform": "scale",
      "min": 0,
      "max": 100
    },
    "octaves": {
      "type": "int",
      "default": 1,
      "uniform": "octaves",
      "min": 1,
      "max": 6
    },
    "colorMode": {
      "type": "int",
      "default": 1,
      "uniform": "colorMode",
      "choices": {
        "mono": 0,
        "rgb": 1
      }
    },
    "dimensions": {
      "type": "int",
      "default": 2,
      "uniform": "dimensions",
      "define": "DIMENSIONS",
      "min": 2,
      "max": 3
    },
    "ridges": {
      "type": "boolean",
      "default": false,
      "uniform": "ridges"
    },
