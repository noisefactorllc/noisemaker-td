    "warpScale": {
      "type": "float",
      "default": 50,
      "uniform": "warpScale",
      "min": 0,
      "max": 100
    },
    "warpIntensity": {
      "type": "float",
      "default": 50,
      "uniform": "warpIntensity",
      "min": 0,
      "max": 100
    },
    "seed": {
      "type": "int",
      "default": 0,
      "uniform": "seed",
      "min": 0,
      "max": 100
    },
    "speed": {
      "type": "int",
      "default": 1,
      "uniform": "speed",
      "min": 0,
      "max": 5,
      "zero": 0
