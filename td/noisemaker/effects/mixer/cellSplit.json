{
  "name": "CellSplit",
  "namespace": "mixer",
  "func": "cellSplit",
  "starter": false,
  "tags": [
    "blend",
    "noise"
  ],
  "description": "Split between inputs using Voronoi cell regions",
  "paramAliases": {},
  "globals": {
    "tex": {
      "type": "surface",
      "default": "none"
    },
    "invert": {
      "type": "int",
      "default": 0,
      "uniform": "invert",
      "choices": {
        "sourceA": 0,
        "sourceB": 1
      }
    },
    "mode": {
      "type": "int",
      "default": 0,
      "uniform": "mode",
      "choices": {
        "edges": 0,
        "split": 1
      }
    },
    "scale": {
      "type": "float",
      "default": 15,
      "uniform": "scale",
      "min": 1,
      "max": 30
    },
    "edgeWidth": {
      "type": "float",
      "default": 0.08,
      "uniform": "edgeWidth",
      "min": 0,
      "max": 0.2
    },
    "seed": {
      "type": "int",
      "default": 1,
      "uniform": "seed",
      "min": 1,
      "max": 100
    },
    "speed": {
      "type": "int",
      "default": 1,
      "uniform": "speed",
      "min": 0,
      "max": 5,
      "zero": 0
    }
  },
  "passes": [
    {
      "name": "render",
      "program": "cellSplit",
      "inputs": {
        "inputTex": "inputTex",
        "tex": "tex"
      },
      "outputs": {
        "fragColor": "outputTex"
      }
    }
  ],
  "textures": {},
  "defaultProgram": "search mixer, synth\n\nsolid(color: #000000)\n.write(o0)\n\nnoise()\n.cellSplit(invert: sourceB)\n.write(o1)\n"
}
