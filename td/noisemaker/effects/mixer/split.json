{
  "name": "Split",
  "namespace": "mixer",
  "func": "split",
  "starter": false,
  "tags": [
    "blend"
  ],
  "description": "Split/wipe between two inputs",
  "paramAliases": {},
  "globals": {
    "tex": {
      "type": "surface",
      "default": "none"
    },
    "invert": {
      "type": "int",
      "default": 0,
      "uniform": "invert",
      "choices": {
        "off": 0,
        "on": 1
      }
    },
    "position": {
      "type": "float",
      "default": 0,
      "uniform": "position",
      "min": -1,
      "max": 1
    },
    "rotation": {
      "type": "float",
      "default": 0,
      "uniform": "rotation",
      "min": -180,
      "max": 180
    },
    "softness": {
      "type": "float",
      "default": 0,
      "uniform": "softness",
      "min": 0,
      "max": 1,
      "zero": 0
    },
    "speed": {
      "type": "int",
      "default": 0,
      "uniform": "speed",
      "min": 0,
      "max": 4,
      "zero": 0
    }
  },
  "passes": [
    {
      "name": "render",
      "program": "split",
      "inputs": {
        "inputTex": "inputTex",
        "tex": "tex"
      },
      "outputs": {
        "fragColor": "outputTex"
      }
    }
  ],
  "textures": {},
  "defaultProgram": "search mixer, synth\n\nnoise(ridges: true, colorMode: mono)\n.write(o0)\n\nnoise(seed: 2, ridges: true)\n.split(tex: read(o0), softness: 1)\n.write(o1)"
}
