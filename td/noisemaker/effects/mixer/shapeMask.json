{
  "name": "ShapeMask",
  "namespace": "mixer",
  "func": "shapeMask",
  "starter": false,
  "tags": [
    "blend",
    "geometric"
  ],
  "description": "Composite inputs inside and outside a geometric shape",
  "paramAliases": {},
  "globals": {
    "tex": {
      "type": "surface",
      "default": "none"
    },
    "invert": {
      "type": "int",
      "default": 0,
      "uniform": "invert",
      "choices": {
        "sourceA": 0,
        "sourceB": 1
      }
    },
    "shape": {
      "type": "int",
      "default": 0,
      "uniform": "shape",
      "choices": {
        "circle": 0,
        "triangle": 1,
        "square": 2,
        "pentagon": 3,
        "hexagon": 4,
        "flower": 5,
        "ring": 6,
        "star": 7
      }
    },
    "radius": {
      "type": "float",
      "default": 0.7,
      "uniform": "radius",
      "min": 0,
      "max": 1
    },
    "edgeSmooth": {
      "type": "float",
      "default": 0.01,
      "uniform": "edgeSmooth",
      "min": 0,
      "max": 0.25,
      "zero": 0
    },
    "rotation": {
      "type": "float",
      "default": 0,
      "uniform": "rotation",
      "min": -180,
      "max": 180
    },
    "posX": {
      "type": "float",
      "default": 0,
      "uniform": "posX",
      "min": -1,
      "max": 1
    },
    "posY": {
      "type": "float",
      "default": 0,
      "uniform": "posY",
      "min": -1,
      "max": 1
    },
    "speed": {
      "type": "int",
      "default": 0,
      "uniform": "speed",
      "min": 0,
      "max": 4,
      "zero": 0
    }
  },
  "passes": [
    {
      "name": "render",
      "program": "shapeMask",
      "inputs": {
        "inputTex": "inputTex",
        "tex": "tex"
      },
      "outputs": {
        "fragColor": "outputTex"
      }
    }
  ],
  "textures": {},
  "defaultProgram": "search mixer, synth\n\nnoise(ridges: true, colorMode: mono)\n.write(o0)\n\nnoise(ridges: true)\n.shapeMask(tex: read(o0))\n.write(o1)"
}
